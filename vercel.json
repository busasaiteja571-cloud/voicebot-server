{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "pom.xml",
      "use": "@vercel/java"
    }
  ],
  "buildCommand": "./mvnw clean package -DskipTests",
  "installCommand": "./mvnw -q -DskipTests dependency:go-offline",
  "env": {
    "JAVA_VERSION": "21",
    "JAVA_TOOL_OPTIONS": "-Xmx512m"
  }
}
